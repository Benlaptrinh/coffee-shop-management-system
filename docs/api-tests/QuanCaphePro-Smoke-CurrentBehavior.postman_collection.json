  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "AUTH-01 Login admin success",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{admin_username}}\",\n  \"password\": \"{{admin_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Has token', function () { pm.expect(body.data.token).to.be.a('string').and.not.empty; });",
                  "pm.environment.set('token_admin', body.data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "AUTH-02 Login staff success",
